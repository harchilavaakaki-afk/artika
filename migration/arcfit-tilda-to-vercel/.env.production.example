# arcfit.ru — Production environment variables
# Скопировать в Vercel project settings → Environment Variables → Production
# (или применить через `deploy.ps1 set-env`)
#
# На текущий момент (2026-05-04) ВСЕ переменные ниже уже залиты в Vercel project arcfit-next через API.
# Этот файл — резервная копия и шаблон для нового окружения.

# ============================================================
# 🟢 ОБЯЗАТЕЛЬНЫЕ — без них формы и аналитика не работают
# ============================================================

# Yandex.Metrika counter ID (тот же что был на Tilda — для сохранения истории визитов)
# Public, видна в client bundle. Используется в src/app/layout.tsx
NEXT_PUBLIC_YM_ID=95693874

# 1C.Fitness lead webhook — приёмник заявок с формы на главной /api/lead
# Тот же URL что использует Tilda → 1C.Fitness CRM → Bitrix24 (sport-vsegda.bitrix24.ru) → email уведомления (info@sport-vsegda.ru, arktikafitness@sport-vsegda.ru)
# ВАЖНО: encrypted в Vercel, не светить в клиентском JS. Используется только в server-side /api/lead/route.ts.
FITNESS_LEAD_WEBHOOK=https://cloud.1c.fitness/api/hs/lead/Tilda/245e31f4-7c6c-4727-90c9-737e631cbf21

# ============================================================
# 🟡 ОПЦИОНАЛЬНЫЕ — для живого расписания вместо FALLBACK
# ============================================================

# 1C.Fitness API для онлайн-расписания и записи. Если не заданы — /api/schedule отдаёт статичный FALLBACK_SCHEDULE из кода (обновляется через skill arcfit-next-schedule раз в неделю).
# FITNESS_API_URL=https://cloud.1c.fitness/api/<account-slug>
# FITNESS_APP_KEY=<app key>
# FITNESS_SECRET_KEY=<secret key>

# ============================================================
# 🔵 СЛУЖЕБНЫЕ — для Claude/CLI деплоя
# ============================================================
# Эти переменные НЕ нужны самому Next.js — они для скриптов deploy.ps1/deploy.sh.
# В deployment окружении не использовать.

# VERCEL_TOKEN=...        ← брать из ~/.claude/secrets/vercel.env (НЕ коммитить!)
# VERCEL_TEAM_ID=team_bv0ra66xYqGMg6DsNOMuoUpm
# VERCEL_PROJECT_ID_ARCFIT_NEXT=prj_zRNjCcSmbjbN8DN8j7RVy61lWkt6
