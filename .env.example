# Database (SQLite default, switch to PostgreSQL when Docker is available)
DATABASE_URL=sqlite+aiosqlite:///./artika.db
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://artika:artika_secret@localhost:5432/artika

# JWT Auth
JWT_SECRET=change-me-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Yandex OAuth (get from https://oauth.yandex.ru/client/new)
YANDEX_OAUTH_TOKEN=
YANDEX_METRIKA_COUNTER_ID=
YANDEX_WEBMASTER_HOST_ID=

# Claude AI (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Sync
SYNC_INTERVAL_MINUTES=60

# CORS
CORS_ORIGINS=["http://localhost:5173"]

# Encryption key for stored API credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=
